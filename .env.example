APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1

POSTGRES_DB=hydrosentinel
POSTGRES_USER=hydrosentinel
POSTGRES_PASSWORD=hydrosentinel
DATABASE_URL=postgresql+psycopg://hydrosentinel:hydrosentinel@postgres:5432/hydrosentinel

JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BOOTSTRAP_ADMIN_EMAIL=admin@hydrosentinel.app
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_NAME=HydroSentinel Admin

FRONTEND_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1